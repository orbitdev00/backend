# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Helius (Solana RPC & API)
HELIUS_API_KEY=your_helius_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_DEGEN_PRICE_ID=price_your_degen_price_id
STRIPE_OMEGA_PRICE_ID=price_your_omega_price_id

# Moralis (optional - for additional chain data)
MORALIS_API_KEY=your_moralis_key_here

# Backend Port
PORT=8000

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local)
# ============================================

# Backend API URL
VITE_BACKEND_URL=http://localhost:8000
# For production: VITE_BACKEND_URL=https://backend-production-a427a.up.railway.app

# Supabase (frontend needs these too)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Admin Secret (for owner panel)
VITE_ADMIN_SECRET=your_admin_secret_here

# ============================================
# LABELBOX AUTOMATION (if using)
# ============================================
LABELBOX_API_KEY=your_labelbox_key_here

# ============================================
# DISCORD BOT (if using)
# ============================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id

# ============================================
# BROWSER AUTOMATION
# ============================================
# Firefox CDP port (default: 9223)
FIREFOX_CDP_PORT=9223
